GROQ_API_KEY=replace-with-server-side-key
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
# Runtime API: pooled Neon endpoint (hostname includes -pooler).
DATABASE_URL=postgresql://user:password@pooled-host/database?sslmode=require
# Alembic only: direct Neon endpoint (hostname does not include -pooler).
# Uses the same database role/password as DATABASE_URL.
MIGRATIONS_DATABASE_URL=postgresql://user:password@direct-host/database?sslmode=require
CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain
CLERK_AUDIENCE=
ALLOWED_ORIGINS=http://localhost:5173
REQUEST_TIMEOUT_SECONDS=8
DOCUMENT_PARSER_TIMEOUT_SECONDS=12
RATE_LIMIT_WINDOW_SECONDS=60
